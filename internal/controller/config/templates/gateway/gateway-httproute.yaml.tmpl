apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: model-registry-{{.Name}}
  namespace: {{.HTTPRouteNamespace}}
  labels:
    app: {{.Name}}
    component: model-registry
    app.kubernetes.io/name: {{.Name}}
    app.kubernetes.io/instance: model-registry-{{.Name}}
    app.kubernetes.io/component: model-registry
    app.kubernetes.io/created-by: model-registry-operator
    app.kubernetes.io/part-of: model-registry
    app.kubernetes.io/managed-by: model-registry-operator
spec:
  parentRefs:
    - group: gateway.networking.k8s.io
      kind: Gateway
      name: {{.GatewayName}}
      namespace: {{.GatewayNamespace}}
  rules:
    - matches:
        - path:
            type: PathPrefix
            value: "/model-registry/{{.Name}}/"
      filters:
        - type: URLRewrite
          urlRewrite:
            path:
              type: ReplacePrefixMatch
              replacePrefixMatch: "/"
      backendRefs:
        - group: ""
          kind: Service
          name: {{.Name}}
          namespace: {{.Namespace}}
          port: {{.Spec.KubeRBACProxy.Port}}
          weight: 1
